# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/content_pipeline?schema=public"

# Auth
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="replace_with_bcrypt_hash"
JWT_SECRET="super_secret_jwt_key_here"
REFRESH_TOKEN_SECRET="super_secret_refresh_key_here"
CRON_SECRET="secret_for_triggering_cron_endpoints"

# AI
# OPEN_ROUTER_API_KEY="your_openrouter_api_key_here"
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Encryption (32-byte hex key for AES-256-GCM to encrypt tokens in DB)
ENCRYPTION_SECRET="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Storage
STORAGE_TYPE="local" # "local" or "s3"
# AWS_S3_BUCKET=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
